# ============================================================================
# PropPilot Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values.
# In Vercel, add these in Project Settings -> Environment Variables.
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase (REQUIRED)
# ----------------------------------------------------------------------------
# Found in: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key (server only — NEVER expose to the browser).
# Found in: Supabase Dashboard -> Project Settings -> API -> service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----------------------------------------------------------------------------
# Application (REQUIRED)
# ----------------------------------------------------------------------------
# The full public URL of your deployment. Used for landing-page links,
# auth redirects and Open Graph metadata.
# Local:  http://localhost:3000
# Vercel: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public-facing brand name. Change in ONE place to rebrand the whole app.
NEXT_PUBLIC_APP_NAME=PropPilot

# Trial duration in days for newly created accounts.
NEXT_PUBLIC_TRIAL_DAYS=7

# NOTE: Per-agent contact details (phone / email / WhatsApp) are stored in the
# `profiles` table and edited in Settings → Profile. They are NOT env vars.

# ----------------------------------------------------------------------------
# Email Notifications — Resend (OPTIONAL until notifications phase)
# ----------------------------------------------------------------------------
RESEND_API_KEY=
# Address platform notifications are sent from.
NOTIFICATIONS_FROM_EMAIL=notifications@yourdomain.com
# Admin alert recipient (e.g. AI outage alerts).
ADMIN_EMAIL=your@email.com

# ----------------------------------------------------------------------------
# Payments — Cashfree Payment Gateway (Phase 6, OPTIONAL)
# ----------------------------------------------------------------------------
# Leave blank to disable online payments: the app runs on the 7-day Pro trial
# and the Billing page shows a friendly note instead of the upgrade button.
# Set both APP_ID and SECRET_KEY to enable real Pro upgrades. The SECRET_KEY is
# used BOTH to authenticate API calls AND to verify webhook signatures
# (Cashfree v2 signs webhooks with the merchant secret key).
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
# sandbox (default) | production
CASHFREE_MODE=sandbox

# ----------------------------------------------------------------------------
# AI Marketing Provider (OPTIONAL)
# ----------------------------------------------------------------------------
# PropPilot ships with a high-quality deterministic template engine that
# works out of the box with NO key. To use a real LLM, set the provider and
# the matching API key. Supported: "template" (default) | "openai" |
# "anthropic" | "gemini".
AI_PROVIDER=template

# Required only when AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Required only when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Required only when AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---------------------------------------------------------------------------
# Error monitoring — Sentry (Phase 8). Fully optional: with no DSN the SDK is a
# no-op and the app runs normally. The public DSN is safe to expose to the
# browser. NEVER commit a real auth token.
# ---------------------------------------------------------------------------
# Public DSN (client + server + edge). Safe to expose.
NEXT_PUBLIC_SENTRY_DSN=
# Org/project slugs + auth token are used ONLY at build time to upload
# source maps (CI). Leave blank locally — source-map upload is skipped.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Optional: sampling + environment overrides.
SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
