# ============================================================================
# PropPilot Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values.
# In Vercel, add these in Project Settings -> Environment Variables.
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase (REQUIRED)
# ----------------------------------------------------------------------------
# Found in: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key (server only — NEVER expose to the browser).
# Found in: Supabase Dashboard -> Project Settings -> API -> service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----------------------------------------------------------------------------
# Application (REQUIRED)
# ----------------------------------------------------------------------------
# The full public URL of your deployment. Used for landing-page links,
# auth redirects and Open Graph metadata.
# Local:  http://localhost:3000
# Vercel: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Agent contact details surfaced on public landing pages.
NEXT_PUBLIC_CONTACT_PHONE=+15551234567
NEXT_PUBLIC_CONTACT_EMAIL=agent@example.com
NEXT_PUBLIC_CONTACT_WHATSAPP=15551234567

# ----------------------------------------------------------------------------
# AI Marketing Provider (OPTIONAL)
# ----------------------------------------------------------------------------
# PropPilot ships with a high-quality deterministic template engine that
# works out of the box with NO key. To use a real LLM, set the provider and
# the matching API key. Supported: "template" (default) | "openai" |
# "anthropic" | "gemini".
AI_PROVIDER=template

# Required only when AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Required only when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Required only when AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
